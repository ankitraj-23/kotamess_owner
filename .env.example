# Supabase credentials for KotaMess Owner
# Copy this file to `.env` and fill in the values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# IMPORTANT: only ever put the PUBLIC anon key here. Never the service_role key.

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Public anon/publishable API key
SUPABASE_ANON_KEY=

# HTTPS page the email confirmation / password-reset links redirect to.
# Must ALSO be added under Supabase -> Authentication -> URL Configuration
# (Site URL and/or Additional Redirect URLs) or the link will show an error.
# Leave blank to fall back to the project's Site URL.
SUPABASE_EMAIL_REDIRECT_URL=https://kotamess-poc.vercel.app
