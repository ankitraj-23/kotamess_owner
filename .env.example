# Supabase credentials for KotaMess Owner
# Copy this file to `.env` and fill in the values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# IMPORTANT: only ever put PUBLIC values here. Never the service_role key, and
# never the Gemini API key — those are server-only secrets (Supabase Edge
# Function secrets), not Flutter env.

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Public publishable (anon) API key. The legacy name SUPABASE_ANON_KEY is also
# accepted for backward compatibility.
SUPABASE_PUBLISHABLE_KEY=

# Optional: HTTPS page the email confirmation / password-reset links redirect
# to. Must ALSO be added under Supabase -> Authentication -> URL Configuration.
# Leave blank to fall back to the project's Site URL.
SUPABASE_EMAIL_REDIRECT_URL=
